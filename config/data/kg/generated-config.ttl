    cla:hasTriggerPolicy cla:TriggerPolicy_570c34426cf9 ;
    cla:isInputMetric true ;
    cla:metricId "매출액영업이익율" ;
    cla:metricValueType cla:VT_ratio ;
    cla:unit cla:UI_percent .

