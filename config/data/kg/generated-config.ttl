    skos:prefLabel "기말현금과현금등가물"^^xsd:string ;
    cla:description "유동자산이 증가하더라도 기말현금과현금등가물 비중이 낮다면 실질 유동성은 기대보다 약할 수 있으므로, 현금성자산 비중이 높을수록 유동자산의 질이 우수하다고 해석할 수 있다." ;
    cla:hasTriggerPolicy cla:TriggerPolicy_570c34426cf9 ;
    cla:isInputMetric true ;
    cla:metricId "기말현금과현금등가물" ;
    cla:metricValueType cla:VT_amount ;
    cla:unit cla:UI_m_krw .

