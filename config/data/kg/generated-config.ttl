cla:PCAR_amount a cla:PeriodChangeAutoRule ;
    cla:appliesToValueType cla:VT_amount ;
    cla:autoThresholdValue 10.0 ;
    cla:resolvedChangeMeasure cla:CM_relative_percent .

cla:PCAR_days a cla:PeriodChangeAutoRule ;
    cla:appliesToValueType cla:VT_days ;
    cla:autoThresholdValue 30.0 ;
    cla:resolvedChangeMeasure cla:CM_absolute .

cla:PCAR_default a cla:PeriodChangeAutoRule ;
    cla:autoThresholdValue 5.0 ;
    cla:isFallbackAutoRule true ;
    cla:resolvedChangeMeasure cla:CM_absolute_points .

cla:PCAR_multiple a cla:PeriodChangeAutoRule ;
    cla:appliesToValueType cla:VT_multiple ;
    cla:autoThresholdValue 0.5 ;
    cla:resolvedChangeMeasure cla:CM_absolute .

cla:PCAR_ratio a cla:PeriodChangeAutoRule ;
    cla:appliesToValueType cla:VT_ratio ;
    cla:autoThresholdValue 5.0 ;
    cla:resolvedChangeMeasure cla:CM_absolute_points .

cla:PeriodChangeAutoPolicy_default a cla:PeriodChangeAutoPolicy ;
    cla:hasAutoResolutionRule cla:PCAR_amount,
        cla:PCAR_days,
        cla:PCAR_multiple,
        cla:PCAR_ratio ;
    cla:hasFallbackAutoResolutionRule cla:PCAR_default .

