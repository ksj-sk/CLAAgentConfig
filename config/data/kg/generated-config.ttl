    cla:metricValueType cla:VT_ratio ;
    cla:unit cla:UI_percent .

cla:Metric_accountsReceivableTurnoverDays a cla:Metric ;
    skos:altLabel "Accounts Receivable Turnover Days"^^xsd:string ;
    skos:prefLabel "매출채권회전기간(일)"^^xsd:string ;
