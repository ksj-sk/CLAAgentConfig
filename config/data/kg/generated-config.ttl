@prefix cla: <https://hit.hanati.co.kr/ontology/cla#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cla:AV_business_performance a cla:AnalyticalView ;
    skos:prefLabel "수익성 + 성장"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsReceivableToRevenueRatio,
        cla:Metric_accountsReceivableTurnoverDays,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_ebit,
        cla:Metric_grossProfitMargin,
        cla:Metric_netProfitMargin,
        cla:Metric_operatingProfitMargin,
        cla:Metric_revenueGrowthRate,
        cla:Metric_totalAssetsGrowthRate ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_cls a cla:AnalyticalView ;
    skos:prefLabel "현금 유동성 확보 현황"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsPayableTurnoverDays,
        cla:Metric_accountsReceivableTurnoverDays,
        cla:Metric_cashFlowBeforeExternalFinancing,
        cla:Metric_fcf,
        cla:Metric_inventoryTurnoverDays,
        cla:Metric_netWorkingCapitalRatio,
        cla:Metric_operatingCashFlow,
        cla:Metric_totalCashDeposits,
        cla:Metric_workingCapital ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_cs_dra a cla:AnalyticalView ;
    skos:prefLabel "종합 건전성 및 부도 위험 분석"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_altmanZScore,
        cla:Metric_dsbi,
        cla:Metric_ebitdaGrowthRate ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_dcs a cla:AnalyticalView ;
    skos:prefLabel "부채/자본 구조"^^xsd:string ;
    cla:guidanceText """- 자본구조·부채 관련 지표는 총차입금·유동·비유동 부채 등 하위 항목 변동과 연결해 서술할 것.
- 부채비율은 본문에서 직접 언급하지 말고, 자기자본비율·차입금의존도 등으로 완곡히 설명할 것.""" ;
    cla:hasTargetMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_borrowingWeight,
        cla:Metric_currentLiabilitiesWeight,
        cla:Metric_currentRatio,
        cla:Metric_debtRatio,
        cla:Metric_equityRatio,
        cla:Metric_netBorrowingRatio,
        cla:Metric_netDebt,
        cla:Metric_tangibleAssetsRatio,
        cla:Metric_totalBorrowings ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_debt_repayment a cla:AnalyticalView ;
    skos:prefLabel "상환능력 + 현금흐름"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_cashFlowToDebt,
        cla:Metric_debtToEbitda,
        cla:Metric_dscr,
        cla:Metric_ebitda,
        cla:Metric_financialCostBurdenRatio,
        cla:Metric_interestCoverageRatio,
        cla:Metric_operatingCashFlow ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_exp_pc a cla:AnalyticalView ;
    skos:prefLabel "수출 및 수익성 변동"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsReceivableToRevenueRatio,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_grossProfitMargin,
        cla:Metric_netProfitMargin,
        cla:Metric_operatingProfitMargin,
        cla:Metric_revenueGrowthRate,
        cla:Metric_sellingGeneralAdminExpenses,
        cla:Metric_sgnaRatio,
        cla:Metric_totalAssetsGrowthRate ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_financial_risk a cla:AnalyticalView ;
    skos:prefLabel "재무구조 + 유동성"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_currentRatio,
        cla:Metric_debtRatio,
        cla:Metric_equityRatio,
        cla:Metric_netBorrowingRatio,
        cla:Metric_netDebt,
        cla:Metric_totalDebt,
        cla:Metric_totalEquity ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_inv_bas a cla:AnalyticalView ;
    skos:prefLabel "투자 및 사업 인수 현황"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_fixedAssetTurnover,
        cla:Metric_nonCurrentAssets,
        cla:Metric_revenueGrowthRate,
        cla:Metric_tangibleAssets,
        cla:Metric_totalAssetTurnover,
        cla:Metric_totalAssetsGrowthRate ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_irc_ocf a cla:AnalyticalView ;
    skos:prefLabel "이자상환능력 및 영업현금흐름"^^xsd:string ;
    cla:guidanceText """- 이자·원리금 상환 여력은 영업이익·영업활동현금흐름·이자비용 간 관계를 표 수치에 근거해 연결할 것.
- DSCR·이자보상배율·현금이자보상배율 중 변동이 큰 지표를 우선 반영할 것.""" ;
    cla:hasTargetMetric cla:Metric_cashFlowToDebt,
        cla:Metric_cashGenerationToOperatingIncomeRatio,
        cla:Metric_cashInterestCoverageRatio,
        cla:Metric_debtToEbitda,
        cla:Metric_dscr,
        cla:Metric_financialCostBurdenRatio,
        cla:Metric_interestCoverageRatio ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_overall a cla:AnalyticalView ;
    skos:prefLabel "전체"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsPayableTurnoverDays,
        cla:Metric_accountsReceivableToRevenueRatio,
        cla:Metric_accountsReceivableTurnoverDays,
        cla:Metric_adjustedEbit,
        cla:Metric_borrowingDependencyRatio,
        cla:Metric_borrowingWeight,
        cla:Metric_cashFlowBeforeExternalFinancing,
        cla:Metric_cashFlowToDebt,
        cla:Metric_cashGenerationToOperatingIncomeRatio,
        cla:Metric_cashInterestCoverageRatio,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_currentLiabilitiesWeight,
        cla:Metric_currentRatio,
        cla:Metric_debtRatio,
        cla:Metric_debtToEbitda,
        cla:Metric_dscr,
        cla:Metric_ebit,
        cla:Metric_equityRatio,
        cla:Metric_fcf,
        cla:Metric_financialCostBurdenRatio,
        cla:Metric_fixedAssetTurnover,
        cla:Metric_grossProfitMargin,
        cla:Metric_interestCoverageRatio,
        cla:Metric_inventoryTurnoverDays,
        cla:Metric_netBorrowingRatio,
        cla:Metric_netDebt,
        cla:Metric_netProfitMargin,
        cla:Metric_netWorkingCapitalRatio,
        cla:Metric_nonCurrentAssets,
        cla:Metric_operatingCashFlow,
        cla:Metric_operatingProfitMargin,
        cla:Metric_principalAndInterestRepayment,
        cla:Metric_revenueGrowthRate,
        cla:Metric_sellingGeneralAdminExpenses,
        cla:Metric_sgnaRatio,
        cla:Metric_tangibleAssets,
        cla:Metric_tangibleAssetsRatio,
        cla:Metric_totalAssetTurnover,
        cla:Metric_totalAssetsGrowthRate,
        cla:Metric_totalBorrowings,
        cla:Metric_totalCashDeposits,
        cla:Metric_totalDebt,
        cla:Metric_totalEquity,
        cla:Metric_workingCapital ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_performance a cla:AnalyticalView ;
    skos:prefLabel "수익성 + 성장"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsReceivableToRevenueRatio,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_fixedAssetTurnover,
        cla:Metric_grossProfitMargin,
        cla:Metric_netProfitMargin,
        cla:Metric_operatingProfitMargin,
        cla:Metric_revenueGrowthRate,
        cla:Metric_tangibleAssetsRatio,
        cla:Metric_totalAssetTurnover,
        cla:Metric_totalAssetsGrowthRate ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_performance_D a cla:AnalyticalView ;
    skos:prefLabel "수익성 + 성장 + 운영 효율"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_accountsReceivable,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_grossProfit,
        cla:Metric_interestExpense,
        cla:Metric_interestIncome,
        cla:Metric_inventory,
        cla:Metric_netIncome,
        cla:Metric_operatingIncome,
        cla:Metric_operatingIncomeToRevenueRatio,
        cla:Metric_revenue,
        cla:Metric_sellingGeneralAdminExpenses ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_pre_calculation a cla:AnalyticalView ;
    skos:prefLabel "기본 계산"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_adjustedEbit,
        cla:Metric_costOfGoodsSold,
        cla:Metric_currentAssets,
        cla:Metric_currentLiabilities,
        cla:Metric_ebit,
        cla:Metric_ebitdaGrowthRate,
        cla:Metric_intangibleAssets,
        cla:Metric_nonCurrentLiabilities,
        cla:Metric_nonOperatingExpenses,
        cla:Metric_nonOperatingIncome,
        cla:Metric_principalAndInterestRepayment,
        cla:Metric_retainedEarningsEtc,
        cla:Metric_totalAssets,
        cla:Metric_totalDebt,
        cla:Metric_totalEquity ;
    cla:isReportable false ;
    cla:viewRole cla:VR_pre_calculation .

cla:AV_risk a cla:AnalyticalView ;
    skos:prefLabel "안정성 + 상환능력"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_borrowingWeight,
        cla:Metric_cashFlowToDebt,
        cla:Metric_cashGenerationToOperatingIncomeRatio,
        cla:Metric_cashInterestCoverageRatio,
        cla:Metric_currentLiabilitiesWeight,
        cla:Metric_currentRatio,
        cla:Metric_debtRatio,
        cla:Metric_debtToEbitda,
        cla:Metric_dscr,
        cla:Metric_equityRatio,
        cla:Metric_fcf,
        cla:Metric_financialCostBurdenRatio,
        cla:Metric_interestCoverageRatio,
        cla:Metric_netBorrowingRatio,
        cla:Metric_netDebt,
        cla:Metric_netWorkingCapitalRatio,
        cla:Metric_workingCapital ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_risk_D a cla:AnalyticalView ;
    skos:prefLabel "재무구조 + 상환능력 + 현금흐름"^^xsd:string ;
    cla:hasTargetMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_currentRatio,
        cla:Metric_debtRatio,
        cla:Metric_ebitda,
        cla:Metric_equityRatio,
        cla:Metric_financingCashFlow,
        cla:Metric_interestCoverageRatio,
        cla:Metric_investingCashFlow,
        cla:Metric_operatingCashFlow,
        cla:Metric_totalBorrowings,
        cla:Metric_workingCapital ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:AV_risk_E a cla:AnalyticalView ;
    skos:prefLabel "안정성 및 상환능력"^^xsd:string ;
    cla:guidanceText """- 표에 있는 활성 지표만 사용하고, 표에 없는 지표·영역은 생략한다.
- 부채비율은 본문에서 직접 언급하지 말고 자기자본비율·차입금의존도·총차입금 중심으로 서술한다.
- 재무안정성/단기지급능력/상환능력 및 재무부담/현금창출력/수익성 변화 관점으로 영역 단위 서술을 구성한다.
- 해석은 가능한 범위에서 전년 대비 -> 업종평균 -> 지표 간 관계 순서를 따른다.
- 표 수치·변화만 근거로 사용하고, 회계 사건·일회성 비용 등 구체 원인 추정은 금지한다.""" ;
    cla:hasTargetGroup cla:CIG_risk_e_cogs_gross_profit,
        cla:CIG_risk_e_debt_service,
        cla:CIG_risk_e_ebitda_gap,
        cla:CIG_risk_e_factoring,
        cla:CIG_risk_e_financial_burden,
        cla:CIG_risk_e_margin_cost_pressure,
        cla:CIG_risk_e_profitability,
        cla:CIG_risk_e_receivables_factoring_signal,
        cla:CIG_risk_e_stability ;
    cla:hasTargetMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_currentRatio,
        cla:Metric_debtToEbitda,
        cla:Metric_ebitda,
        cla:Metric_equityRatio,
        cla:Metric_interestCoverageRatio,
        cla:Metric_netIncome,
        cla:Metric_operatingCashFlow,
        cla:Metric_operatingIncome,
        cla:Metric_operatingIncomeToRevenueRatio,
        cla:Metric_receivablesAssignmentAmount,
        cla:Metric_totalBorrowings ;
    cla:isReportable true ;
    cla:viewRole cla:VR_analysis .

cla:CIG_risk_e_cogs_gross_profit a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_cogs_gross_profit" ;
    cla:guidanceText "매출원가율이 상승하면 같은 매출액 기준에서 매출총이익은 감소하는 방향으로 움직이므로, 원가통제 수준이 약화될수록 본업의 1차 수익창출력도 함께 저하될 가능성이 높다." ;
    cla:hasActivationMetric cla:Metric_costOfGoodsSoldRatio ;
    cla:includesMetric cla:Metric_grossProfit,
        cla:Metric_operatingIncome ;
    cla:isEnabled true .

cla:CIG_risk_e_debt_service a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_debt_service" ;
    cla:guidanceText "EBITDA가 증가하더라도 총차입금과 이자비용이 더 빠르게 늘면 이자보상배율 개선이 제한될 수 있어, 상환여력 평가는 수익창출력과 부채부담을 함께 봐야 한다. 수익창출력 관점은 영업활동현금흐름과 EBITDA를 함께 비교한다." ;
    cla:hasActivationMetric cla:Metric_ebitda,
        cla:Metric_interestCoverageRatio ;
    cla:includesMetric cla:Metric_debtToEbitda,
        cla:Metric_operatingCashFlow ;
    cla:isEnabled true .

cla:CIG_risk_e_ebitda_gap a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_ebitda_gap" ;
    cla:guidanceText "영업이익은 양호하지만 EBITDA와의 차이가 크면 감가상각비 등 비현금성비용 영향이 크다는 뜻일 수 있고, 당기순이익이 더 약하다면 금융비용이나 비영업손실 부담이 크다고 해석할 수 있다." ;
    cla:hasActivationMetric cla:Metric_ebitda,
        cla:Metric_netIncome,
        cla:Metric_operatingIncome ;
    cla:includesMetric cla:Metric_interestExpense ;
    cla:isEnabled true .

cla:CIG_risk_e_factoring a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_factoring" ;
    cla:guidanceText "매출채권·재고자산 증가로 운전자본이 확대되면 영업현금이 약해질 수 있고, 당기순이익과 비교하면 이익의 질, 기말현금과 비교하면 유동성 지속성을 판단할 수 있다." ;
    cla:hasActivationMetric cla:Metric_accountsReceivable,
        cla:Metric_inventory ;
    cla:includesMetric cla:Metric_netIncome,
        cla:Metric_operatingCashFlow,
        cla:Metric_receivablesAssignmentAmount ;
    cla:isEnabled true .

cla:CIG_risk_e_financial_burden a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_financial_burden" ;
    cla:guidanceText "영업이익 대비 당기순이익이 약할수록 이자비용 등 금융손익 부담이 크게 작용한 것으로 볼 수 있고, 이자수익이 증가하면 그 부담을 일부 완화하는 요인으로 해석할 수 있다." ;
    cla:hasActivationMetric cla:Metric_netIncome,
        cla:Metric_operatingIncome ;
    cla:includesMetric cla:Metric_interestExpense,
        cla:Metric_interestIncome ;
    cla:isEnabled true .

cla:CIG_risk_e_margin_cost_pressure a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_margin_cost_pressure" ;
    cla:guidanceText "매출액영업이익율이 하락할 때 매출원가율 상승과 판관비 증가가 함께 나타난다면, 이는 원가와 비용 부담이 동시에 확대되어 운영효율이 전반적으로 저하되고 있음을 시사한다." ;
    cla:hasActivationMetric cla:Metric_operatingIncomeToRevenueRatio ;
    cla:includesMetric cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_sellingGeneralAdminExpenses ;
    cla:isEnabled true .

cla:CIG_risk_e_profitability a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_profitability" ;
    cla:guidanceText "수익성 변화 관점에서 매출원가율 -> 영업이익 -> 당기순이익 흐름으로 연결하고, 변동이 큰 지표를 우선 설명한다." ;
    cla:hasActivationMetric cla:Metric_costOfGoodsSoldRatio,
        cla:Metric_netIncome,
        cla:Metric_operatingIncome,
        cla:Metric_operatingIncomeToRevenueRatio ;
    cla:isEnabled true .

cla:CIG_risk_e_receivables_factoring_signal a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_receivables_factoring_signal" ;
    cla:guidanceText "기업이 외상매출채권을 담보대출·팩토링 등으로 현금화한 규모를 뜻하므로, 자금사정과 운전자금 의존도를 보여주는 지표로, 금액이 크고 반복되면 유동성 압박 신호로 해석할 수 있고, 반대로 업종 특성상 일시적으로 쓰는 수준이면 정상적인 자금조달 수단으로 설명한다." ;
    cla:hasActivationMetric cla:Metric_receivablesAssignmentAmount ;
    cla:includesMetric cla:Metric_accountsReceivable,
        cla:Metric_netIncome,
        cla:Metric_operatingCashFlow ;
    cla:isEnabled true .

cla:CIG_risk_e_stability a cla:CompositeInterpretationGroup ;
    cla:groupId "risk_e_stability" ;
    cla:guidanceText "총차입금 증가는 이자비용·차입금의존도·부채비율 상승으로 이어질 수 있으며, 수익창출력이 충분히 뒷받침되지 않으면 이자보상배율 하락을 통해 차입부담 확대가 나타날 수 있다." ;
    cla:hasActivationMetric cla:Metric_borrowingDependencyRatio,
        cla:Metric_totalBorrowings ;
    cla:includesMetric cla:Metric_debtRatio,
        cla:Metric_interestCoverageRatio,
        cla:Metric_interestExpense ;
    cla:isEnabled true .

cla:Formula_accountsReceivableToRevenueRatio a cla:Formula ;
    cla:formulaText "매출채권 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_accountsReceivable,
        cla:Metric_revenue .

cla:Formula_adjustedEbit a cla:Formula ;
    cla:formulaText "영업이익 + (영업외수익 - 이자수익) - (영업외비용 - 이자비용)" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_interestIncome,
        cla:Metric_nonOperatingExpenses,
        cla:Metric_nonOperatingIncome,
        cla:Metric_operatingIncome .

cla:Formula_altmanZScore a cla:Formula ;
    cla:formulaText "1.2 * (운전자본/자산총계) + 1.4 * (잉여금등/자산총계) + 3.3 * (EBIT/자산총계) + 0.6 * (자본총계/부채총계) + 1.0 * (매출액/자산총계)" ;
    cla:hasOperand cla:Metric_ebit,
        cla:Metric_retainedEarningsEtc,
        cla:Metric_revenue,
        cla:Metric_totalAssets,
        cla:Metric_totalDebt,
        cla:Metric_totalEquity,
        cla:Metric_workingCapital .

cla:Formula_borrowingDependencyRatio a cla:Formula ;
    cla:formulaText "총차입금 / 자산총계 * 100" ;
    cla:hasOperand cla:Metric_totalAssets,
        cla:Metric_totalBorrowings .

cla:Formula_borrowingWeight a cla:Formula ;
    cla:formulaText "총차입금 / 부채총계 * 100" ;
    cla:hasOperand cla:Metric_totalBorrowings,
        cla:Metric_totalDebt .

cla:Formula_bsGearing a cla:Formula ;
    cla:formulaText "총차입금 / Tangible Net Worth * 100" ;
    cla:hasOperand cla:Metric_tangibleNetWorth,
        cla:Metric_totalBorrowings .

cla:Formula_cashFlowToDebt a cla:Formula ;
    cla:formulaText "영업활동현금흐름 / 부채총계" ;
    cla:hasOperand cla:Metric_operatingCashFlow,
        cla:Metric_totalDebt .

cla:Formula_cashGenerationToOperatingIncomeRatio a cla:Formula ;
    cla:formulaText "영업활동현금흐름 / 영업이익 * 100" ;
    cla:hasOperand cla:Metric_operatingCashFlow,
        cla:Metric_operatingIncome .

cla:Formula_cashInterestCoverageRatio a cla:Formula ;
    cla:formulaText "영업활동현금흐름 / 이자비용" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_operatingCashFlow .

cla:Formula_cashRatio a cla:Formula ;
    cla:formulaText "총현금예금 / 유동부채 * 100" ;
    cla:hasOperand cla:Metric_currentLiabilities,
        cla:Metric_totalCashDeposits .

cla:Formula_ccc a cla:Formula ;
    cla:formulaText "매출채권회전기간(일) + 재고자산회전기간(일) - 매입채무회전기간(일)" ;
    cla:hasOperand cla:Metric_accountsPayableTurnoverDays,
        cla:Metric_accountsReceivableTurnoverDays,
        cla:Metric_inventoryTurnoverDays .

cla:Formula_costOfGoodsSoldRatio a cla:Formula ;
    cla:formulaText "매출원가 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_costOfGoodsSold,
        cla:Metric_revenue .

cla:Formula_currentLiabilitiesWeight a cla:Formula ;
    cla:formulaText "유동부채 / 부채총계 * 100" ;
    cla:hasOperand cla:Metric_currentLiabilities,
        cla:Metric_totalDebt .

cla:Formula_currentRatio a cla:Formula ;
    cla:formulaText "유동자산 / 유동부채 * 100" ;
    cla:hasOperand cla:Metric_currentAssets,
        cla:Metric_currentLiabilities .

cla:Formula_debtRatio a cla:Formula ;
    cla:formulaText "부채총계 / 자본총계 × 100" ;
    cla:hasOperand cla:Metric_totalDebt,
        cla:Metric_totalEquity .

cla:Formula_debtToEbitda a cla:Formula ;
    cla:formulaText "총차입금 / EBITDA" ;
    cla:hasOperand cla:Metric_ebitda,
        cla:Metric_totalBorrowings .

cla:Formula_dsbi a cla:Formula ;
    cla:formulaText "(이자비용 + 원리금상환액) / 영업활동현금흐름" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_operatingCashFlow,
        cla:Metric_principalAndInterestRepayment .

cla:Formula_dscr a cla:Formula ;
    cla:formulaText "(영업활동현금흐름 + 이자비용) / (이자비용 + 원리금상환액)" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_operatingCashFlow,
        cla:Metric_principalAndInterestRepayment .

cla:Formula_ebit a cla:Formula ;
    cla:formulaText "영업이익 + 영업외수익 - 영업외비용" ;
    cla:hasOperand cla:Metric_nonOperatingExpenses,
        cla:Metric_nonOperatingIncome,
        cla:Metric_operatingIncome .

cla:Formula_ebitdaMargin a cla:Formula ;
    cla:formulaText "EBITDA / 매출액 * 100" ;
    cla:hasOperand cla:Metric_ebitda,
        cla:Metric_revenue .

cla:Formula_equityRatio a cla:Formula ;
    cla:formulaText "자본총계 / 자산총계 × 100" ;
    cla:hasOperand cla:Metric_totalAssets,
        cla:Metric_totalEquity .

cla:Formula_fcf a cla:Formula ;
    cla:formulaText "영업활동현금흐름 + 투자활동현금흐름" ;
    cla:hasOperand cla:Metric_investingCashFlow,
        cla:Metric_operatingCashFlow .

cla:Formula_financialCostBurdenRatio a cla:Formula ;
    cla:formulaText "이자비용 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_revenue .

cla:Formula_fixedAssetTurnover a cla:Formula ;
    cla:formulaText "매출액 / 유형자산" ;
    cla:hasOperand cla:Metric_revenue,
        cla:Metric_tangibleAssets .

cla:Formula_fixedLongTermSuitabilityRatio a cla:Formula ;
    cla:formulaText "비유동자산 / (비유동부채 + 자본총계) * 100" ;
    cla:hasOperand cla:Metric_nonCurrentAssets,
        cla:Metric_nonCurrentLiabilities,
        cla:Metric_totalEquity .

cla:Formula_grossProfitMargin a cla:Formula ;
    cla:formulaText "매출총이익 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_grossProfit,
        cla:Metric_revenue .

cla:Formula_interestCover a cla:Formula ;
    cla:formulaText "EBITDA / 이자비용" ;
    cla:hasOperand cla:Metric_ebitda,
        cla:Metric_interestExpense .

cla:Formula_interestCoverageRatio a cla:Formula ;
    cla:formulaText "영업이익 / 이자비용" ;
    cla:hasOperand cla:Metric_interestExpense,
        cla:Metric_operatingIncome .

cla:Formula_netBorrowingRatio a cla:Formula ;
    cla:formulaText "Net Debt / 자본총계 * 100" ;
    cla:hasOperand cla:Metric_netDebt,
        cla:Metric_totalEquity .

cla:Formula_netDebt a cla:Formula ;
    cla:formulaText "총차입금 - 총현금예금" ;
    cla:hasOperand cla:Metric_totalBorrowings,
        cla:Metric_totalCashDeposits .

cla:Formula_netProfitMargin a cla:Formula ;
    cla:formulaText "당기순이익 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_netIncome,
        cla:Metric_revenue .

cla:Formula_netWorkingCapitalRatio a cla:Formula ;
    cla:formulaText "운전자본 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_revenue,
        cla:Metric_workingCapital .

cla:Formula_operatingProfitMargin a cla:Formula ;
    cla:formulaText "영업이익 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_operatingIncome,
        cla:Metric_revenue .

cla:Formula_roa a cla:Formula ;
    cla:formulaText "당기순이익 / 자산총계 * 100" ;
    cla:hasOperand cla:Metric_netIncome,
        cla:Metric_totalAssets .

cla:Formula_roe a cla:Formula ;
    cla:formulaText "당기순이익 / 자본총계 * 100" ;
    cla:hasOperand cla:Metric_netIncome,
        cla:Metric_totalEquity .

cla:Formula_sgnaRatio a cla:Formula ;
    cla:formulaText "판매비와관리비 / 매출액 * 100" ;
    cla:hasOperand cla:Metric_revenue,
        cla:Metric_sellingGeneralAdminExpenses .

cla:Formula_tangibleAssetsRatio a cla:Formula ;
    cla:formulaText "유형자산 / 자산총계 * 100" ;
    cla:hasOperand cla:Metric_tangibleAssets,
        cla:Metric_totalAssets .

cla:Formula_tangibleNetWorth a cla:Formula ;
    cla:formulaText "자산총계 - 무형자산" ;
    cla:hasOperand cla:Metric_intangibleAssets,
        cla:Metric_totalAssets .

cla:Formula_totalAssetTurnover a cla:Formula ;
    cla:formulaText "매출액 / 자산총계" ;
    cla:hasOperand cla:Metric_revenue,
        cla:Metric_totalAssets .

cla:Formula_totalDebt a cla:Formula ;
    cla:formulaText "유동부채 + 비유동부채" ;
    cla:hasOperand cla:Metric_currentLiabilities,
        cla:Metric_nonCurrentLiabilities .

cla:Formula_totalEquity a cla:Formula ;
    cla:formulaText "자산총계 - 부채총계" ;
    cla:hasOperand cla:Metric_totalAssets,
        cla:Metric_totalDebt .

cla:Formula_workingCapital a cla:Formula ;
    cla:formulaText "유동자산 - 유동부채" ;
    cla:hasOperand cla:Metric_currentAssets,
        cla:Metric_currentLiabilities .

cla:Metric_accountsPayableTurnoverDays a cla:Metric ;
    skos:altLabel "Accounts Payable Turnover Days"^^xsd:string ;
    skos:prefLabel "매입채무회전기간(일)"^^xsd:string ;
