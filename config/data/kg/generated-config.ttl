    cla:hasTriggerPolicy cla:TriggerPolicy_570c34426cf9 ;
    cla:isInputMetric true ;
    cla:metricId "매출채권회전기간(일)" ;
    cla:metricValueType cla:VT_days ;
    cla:unit cla:UI_days .

cla:Metric_adjustedEbit a cla:Metric ;
    skos:altLabel "Adjusted EBIT"^^xsd:string ;
    skos:prefLabel "조정형EBIT"^^xsd:string ;
    cla:description "순수 영업기반 수익성" ;
