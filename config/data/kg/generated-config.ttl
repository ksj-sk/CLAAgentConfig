cla:Metric_borrowingDependencyRatio a cla:Metric ;
    skos:altLabel "Borrowing Dependency Ratio"^^xsd:string ;
    skos:prefLabel "차입금의존도"^^xsd:string ;
    cla:description "전체 자산 중 차입금의 비중을 나타내며, 30% 이하이면 재무구조 양호" ;
    cla:hasFormula cla:Formula_borrowingDependencyRatio ;
    cla:hasTriggerPolicy cla:TriggerPolicy_99bce6d3a942 ;
    cla:isInputMetric false ;
    cla:metricId "차입금의존도" ;
    cla:metricValueType cla:VT_ratio ;
    cla:unit cla:UI_percent .

cla:Metric_borrowingWeight a cla:Metric ;
