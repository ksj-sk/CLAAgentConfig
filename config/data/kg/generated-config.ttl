    cla:hasTriggerPolicy cla:TriggerPolicy_570c34426cf9 ;
    cla:isInputMetric true ;
    cla:metricId "매출채권" ;
    cla:metricValueType cla:VT_amount ;
    cla:unit cla:UI_m_krw .

cla:Metric_accountsReceivableToRevenueRatio a cla:Metric ;
    skos:altLabel "Accounts Receivable to Revenue Ratio"^^xsd:string ;
    skos:prefLabel "매출채권/매출액 비율"^^xsd:string ;
