cla:Unit
  a skos:ConceptScheme ;
  skos:editorialNote "Metric.cla:unit=UnitItem(UI_*). value_type: 예약 변환(ratio→percent, amount→m_krw) 후 lookup notation으로 조회; 그 외 value_type은 그대로 notation 조회. §02-data-construction 2.1.6." ;
  skos:prefLabel "지표 기준 단위"@ko ;
.
cla:UnitCategory
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:prefLabel "단위 유형"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:unitLabel ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "단위 표현" ;
    ] ;
.
cla:UnitItem
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:prefLabel "단위 항목"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:unitLabel ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "단위 표현" ;
    ] ;
.
cla:VR_analysis
  a skos:Concept ;
  skos:inScheme cla:ViewRole ;
  skos:notation "analysis" ;
  skos:prefLabel "분석 관점"@ko ;
.
cla:VR_pre_calculation
  a skos:Concept ;
  skos:editorialNote """현재 YAML 설정 파일에서 base에 해당하는 부분을 정의
- 입력 JSON에 포함되어 있지 않지만 다양한 부분에서 활용이 필요해서 사전 계산 용도로 필요한 지표들""" ;
  skos:inScheme cla:ViewRole ;
  skos:notation "base" ;
  skos:prefLabel "사전 계산"@ko ;
.
cla:VT_amount
  a skos:Concept ;
  skos:inScheme cla:ValueType ;
  skos:notation "amount" ;
  skos:prefLabel "금액"@ko ;
.
cla:VT_days
  a skos:Concept ;
  skos:inScheme cla:ValueType ;
  skos:notation "days" ;
  skos:prefLabel "기간(일)"@ko ;
.
cla:VT_multiple
  a skos:Concept ;
  skos:inScheme cla:ValueType ;
  skos:notation "multiple" ;
  skos:prefLabel "배수"@ko ;
.
cla:VT_ratio
  a skos:Concept ;
  skos:inScheme cla:ValueType ;
  skos:notation "ratio" ;
  skos:prefLabel "비율"@ko ;
.
cla:ValueType
  a skos:ConceptScheme ;
  skos:editorialNote "YAML metrics[*].value_type. DTM_auto 시 PeriodChangeThresholdRule.appliesToValueType으로 연결."@ko ;
  skos:prefLabel "지표 값 유형"@ko ;
.
cla:ViewRole
  a skos:ConceptScheme ;
  skos:editorialNote "YAML 최상위 섹션 키: `base`→notation `base`(VR_pre_calculation). 그 외 섹션(dcs, irc 등)→notation `analysis`(VR_analysis)." ;
  skos:prefLabel "관점 역할"@ko ;
.
cla:all
  a skos:Concept ;
  skos:definition "AND 연산자로써의 역할"@ko ;
  skos:inScheme cla:CombineOperator ;
  skos:notation "all" ;
  skos:prefLabel "모두"@ko ;
.
cla:any
  a skos:Concept ;
  skos:definition "OR 연산자로써의 역할"@ko ;
  skos:inScheme cla:CombineOperator ;
  skos:notation "any" ;
  skos:prefLabel "일부"@ko ;
.
cla:appliesToValueType
  a owl:ObjectProperty ;
  rdfs:domain cla:PeriodChangeThresholdRule ;
  rdfs:range skos:Concept ;
  skos:definition "value_type 슬롯 식별. DTM_auto 시 이 규칙이 적용됨."@ko ;
.
cla:changeMeasure
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerCondition ;
  rdfs:range skos:Concept ;
  skos:definition "지표별 명시 기간 변화 측정(ExplicitChangeMeasure). default policy 조건에는 사용하지 않음."@ko ;
  skos:prefLabel "기간 변화 측정"@ko ;
.
cla:combineOperator
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range skos:Concept ;
  skos:prefLabel "조합 연산자"@ko ;
.
cla:conditionType
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerCondition ;
  rdfs:range skos:Concept ;
  skos:prefLabel "조건 유형"@ko ;
.
cla:defaultThresholdMode
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range skos:Concept ;
  skos:definition "_defaults.triggers 전용. period_change_thresholds 테이블 해석 모드(auto|absolute|relative_percent)."@ko ;
  skos:prefLabel "기본 임계값 모드"@ko ;
.
cla:description
  a owl:DatatypeProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range xsd:string ;
  skos:prefLabel "지표 설명"@ko ;
.
cla:formulaText
  a owl:DatatypeProperty ;
  rdfs:domain cla:Formula ;
  rdfs:range xsd:string ;
  skos:editorialNote """- python eval로 동작 가능할 수준의 계산식 작성이 필요.
- 각 지표 값은 Metric의 prefLabel 또는 metricId 값 형태로 구성.""" ;
  skos:prefLabel "계산식"@ko ;
.
cla:groupId
