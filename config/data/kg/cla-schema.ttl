# baseURI: https://hit.hanati.co.kr/ontology/cla
# imports: http://spinrdf.org/spin
# imports: http://www.w3.org/2004/02/skos/core
# imports: http://www.w3.org/ns/shacl#
# prefix: cla

@prefix : <https://hit.hanati.co.kr/ontology/cla#> .
@prefix arg: <http://spinrdf.org/arg#> .
@prefix cla: <https://hit.hanati.co.kr/ontology/cla#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sp: <http://spinrdf.org/sp#> .
@prefix spin: <http://spinrdf.org/spin#> .
@prefix spl: <http://spinrdf.org/spl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://hit.hanati.co.kr/ontology/cla>
  a owl:Ontology ;
  owl:imports <http://spinrdf.org/spin> ;
  owl:imports <http://www.w3.org/2004/02/skos/core> ;
  owl:imports sh: ;
  sh:declare [
      sh:namespace "https://hit.hanati.co.kr/ontology/cla#" ;
      sh:prefix "cla" ;
    ] ;
.
cla:AnalyticalView
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "analytical view"@en ;
  skos:prefLabel "분석 관점"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:guidanceText ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:name "해석 가이드" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasTargetGroup ;
      sh:class cla:CompositeInterpretationGroup ;
      sh:name "복합 해석" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasTargetMetric ;
      sh:class cla:Metric ;
      sh:minCount 1 ;
      sh:name "분석 대상 지표" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isReportable ;
      sh:datatype xsd:boolean ;
      sh:defaultValue true ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "분석 여부" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:viewRole ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "관점 역할" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ViewRole ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
.
cla:CM_absolute
  a skos:Concept ;
  skos:inScheme cla:ExplicitChangeMeasure ;
  skos:notation "absolute" ;
  skos:prefLabel "절대"@ko ;
.
cla:CM_absolute_points
  a skos:Concept ;
  skos:inScheme cla:ExplicitChangeMeasure ;
  skos:notation "absolute_points" ;
  skos:prefLabel "퍼센트포인트"@ko ;
.
cla:CM_relative_percent
  a skos:Concept ;
  skos:inScheme cla:ExplicitChangeMeasure ;
  skos:notation "relative_percent" ;
  skos:prefLabel "상대 퍼센트"@ko ;
.
cla:CT_decrease_rate_threshold
  a skos:Concept ;
  skos:editorialNote "미사용·예약; YAML/엔진 미지원"@ko ;
  skos:inScheme cla:ConditionType ;
.
cla:CT_difference_above_threshold
  a skos:Concept ;
  skos:editorialNote "미사용·예약; YAML/엔진 미지원"@ko ;
  skos:inScheme cla:ConditionType ;
.
cla:CT_difference_below_threshold
  a skos:Concept ;
  skos:editorialNote "미사용·예약; YAML/엔진 미지원"@ko ;
  skos:inScheme cla:ConditionType ;
.
cla:CT_increase_rate_threshold
  a skos:Concept ;
  skos:editorialNote "미사용·예약; YAML/엔진 미지원"@ko ;
  skos:inScheme cla:ConditionType ;
.
cla:CT_industry_vs_company
  a skos:Concept ;
  skos:inScheme cla:ConditionType ;
  skos:notation "industry_vs_company" ;
  skos:prefLabel "업계 대비 기업"@ko ;
.
cla:CT_period_change_threshold
  a skos:Concept ;
  skos:inScheme cla:ConditionType ;
  skos:notation "period_change_threshold" ;
  skos:prefLabel "기간 변화 임계"@ko ;
.
cla:CT_sign_cross_zero
  a skos:Concept ;
  skos:inScheme cla:ConditionType ;
  skos:notation "sign_cross_zero" ;
  skos:prefLabel "부호 전환(영점 교차)"@ko ;
.
cla:ChangeMeasure
  a skos:ConceptScheme ;
  skos:editorialNote "Deprecated: ExplicitChangeMeasure·DefaultThresholdMode로 분리. 하위 호환 문서용."@ko ;
  skos:prefLabel "기간 변화 측정 방식(구)"@ko ;
.
cla:CombineOperator
  a skos:ConceptScheme ;
  skos:prefLabel "조합 연산자"@ko ;
.
cla:CompositeInterpretationGroup
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "composite interpretation group"@en ;
  skos:prefLabel "복합 해석 그룹"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:groupId ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "복합 해석 그룹 식별자" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:guidanceText ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:name "해석 가이드" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasActivationMetric ;
      sh:class cla:Metric ;
      sh:minCount 1 ;
      sh:name "복합 해석 활성 지표" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasTriggerPolicy ;
      sh:class cla:TriggerPolicy ;
      sh:maxCount 1 ;
      sh:name "트리거 정책" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:includesMetric ;
      sh:class cla:Metric ;
      sh:name "복합 해석 포함 지표" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isEnabled ;
      sh:datatype xsd:boolean ;
      sh:maxCount 1 ;
      sh:name "활성 여부" ;
    ] ;
.
cla:ConditionType
  a skos:ConceptScheme ;
  skos:editorialNote "YAML conditions[].type은 skos:notation으로 매핑(v0.8.5: period_change_threshold, sign_cross_zero, industry_vs_company 3종). 구 notation(change_rate_threshold 등)은 TBox·빌드에서 거부. 미사용 Concept(CT_decrease_rate_threshold 등)은 SHACL/빌드 검증 대상에서 제외 권장." ;
  skos:prefLabel "조건유형"@ko ;
.
cla:DTM_absolute
  a skos:Concept ;
  skos:inScheme cla:DefaultThresholdMode ;
  skos:notation "absolute" ;
  skos:prefLabel "절대차(기본 테이블)"@ko ;
.
cla:DTM_auto
  a skos:Concept ;
  skos:inScheme cla:DefaultThresholdMode ;
  skos:notation "auto" ;
  skos:prefLabel "자동(지표 value_type 기준)"@ko ;
.
cla:DTM_relative_percent
  a skos:Concept ;
  skos:inScheme cla:DefaultThresholdMode ;
  skos:notation "relative_percent" ;
  skos:prefLabel "상대 퍼센트(기본 테이블)"@ko ;
.
cla:DefaultThresholdMode
  a skos:ConceptScheme ;
  skos:definition "_defaults.triggers.defaultThresholdMode 전용. period_change_thresholds 테이블 해석 모드."@ko ;
  skos:prefLabel "기본 임계값 모드"@ko ;
.
cla:ExplicitChangeMeasure
  a skos:ConceptScheme ;
  skos:definition "지표별 triggers.conditions[].measure 전용 명시 측정 방식."@ko ;
  skos:prefLabel "명시 기간 변화 측정"@ko ;
.
cla:Formula
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "formula"@en ;
  skos:prefLabel "지표 계산식"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:formulaText ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "계산식" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasOperand ;
      sh:class cla:Metric ;
      sh:minCount 1 ;
      sh:name "산식 활용 지표" ;
      sh:nodeKind sh:IRI ;
    ] ;
.
cla:ICM_abs_diff
  a skos:Concept ;
  skos:inScheme cla:IndustryComparisonMode ;
  skos:notation "abs_diff" ;
  skos:prefLabel "절대 차이"@ko ;
.
cla:ICM_relative_to_industry
  a skos:Concept ;
  skos:inScheme cla:IndustryComparisonMode ;
  skos:notation "relative_to_industry" ;
  skos:prefLabel "업계 대비 상대"@ko ;
.
cla:IndustryComparisonMode
  a skos:ConceptScheme ;
  skos:prefLabel "업계 비교 방식"@ko ;
.
cla:Metric
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "metric"@en ;
  skos:editorialNote "hasTriggerPolicy가 없으면 트리거 필터 없이 해석 테이블에 전체 포함(기본 포함). 명시적 always/when_triggered는 TriggerPolicy로 표현."@ko ;
  skos:prefLabel "지표"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path skos:altLabel ;
      sh:datatype xsd:string ;
      sh:name "지표명 (동의어)" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path skos:prefLabel ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "지표명" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:description ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:name "지표 설명" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasFormula ;
      sh:class cla:Formula ;
      sh:maxCount 1 ;
      sh:name "지표 계산식" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasTriggerPolicy ;
      skos:editorialNote "없음=필터 없이 전체 포함. 있음=TriggerPolicy.triggerMode에 따라 평가(always는 조건 생략, when_triggered는 조건 평가)."@ko ;
      sh:class cla:TriggerPolicy ;
      sh:maxCount 1 ;
      sh:name "지표 트리거 정책" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isInputMetric ;
      sh:datatype xsd:boolean ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "입력 지표 여부" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:metricCategory ;
      sh:class skos:Concept ;
      sh:name "지표 분류 유형" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:MetricCategory ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:metricId ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "지표 식별자" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:metricValueType ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:name "지표 값 유형" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ValueType ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:unit ;
      sh:class skos:Concept ;
      sh:defaultValue cla:UI_m_krw ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "기준 단위" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:Unit ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "defaultThresholdMode=auto policy requires metricValueType on Metric"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  FILTER (
    EXISTS {
      $this cla:hasTriggerPolicy ?tp .
      ?tp cla:isDefaultTriggerPolicy true ;
           cla:defaultThresholdMode cla:DTM_auto ;
           cla:hasTriggerCondition ?tc .
      ?tc cla:conditionType cla:CT_period_change_threshold .
      OPTIONAL { ?tc cla:thresholdValue ?tv }
      FILTER ( !BOUND(?tv) )
    } ||
    EXISTS {
      ?cig cla:hasActivationMetric $this ;
           cla:hasTriggerPolicy ?tp .
      ?tp cla:isDefaultTriggerPolicy true ;
           cla:defaultThresholdMode cla:DTM_auto ;
           cla:hasTriggerCondition ?tc .
      ?tc cla:conditionType cla:CT_period_change_threshold .
      OPTIONAL { ?tc cla:thresholdValue ?tv }
      FILTER ( !BOUND(?tv) )
    }
  )
  FILTER NOT EXISTS { $this cla:metricValueType ?vt }
}""" ;
    ] ;
.
cla:MetricCategory
  a skos:ConceptScheme ;
  skos:prefLabel "지표의 분류 유형"@ko ;
.
cla:PeriodChangeThresholdPolicy
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:definition "_defaults.period_change_thresholds value_type별 임계값 테이블. DTM_auto/absolute/relative_percent 및 measure:auto 해석에 공통 사용."@ko ;
  skos:prefLabel "기간 변화 기본 임계값 정책"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasFallbackThresholdRule ;
      sh:class cla:PeriodChangeThresholdRule ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "폴백 임계값 규칙" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasValueTypeThresholdRule ;
      sh:class cla:PeriodChangeThresholdRule ;
      sh:minCount 4 ;
      sh:name "value_type별 임계값 규칙" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "each ValueType must have exactly one PeriodChangeThresholdRule in the policy (D-8)"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  ?vt skos:inScheme cla:ValueType .
  {
    SELECT (COUNT(?rule) AS ?cnt) WHERE {
      $this cla:hasValueTypeThresholdRule ?rule .
      ?rule cla:appliesToValueType ?vt .
    }
  }
  FILTER (?cnt != 1)
}""" ;
    ] ;
.
cla:PeriodChangeThresholdPolicySingletonShape
  a sh:NodeShape ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "exactly one PeriodChangeThresholdPolicy must exist in the data graph" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  {
    SELECT (COUNT(?p) AS ?cnt) WHERE { ?p a cla:PeriodChangeThresholdPolicy }
  }
  FILTER (?cnt != 1)
}""" ;
    ] ;
  sh:targetClass cla:PeriodChangeThresholdPolicy ;
.
cla:PeriodChangeThresholdRule
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:definition "value_type 슬롯별 임계값 및(DTM_auto 시) resolvedChangeMeasure 해석 규칙"@ko ;
  skos:prefLabel "기간 변화 임계값 규칙"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:appliesToValueType ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:name "적용 value_type" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ValueType ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isFallbackThresholdRule ;
      sh:datatype xsd:boolean ;
      sh:maxCount 1 ;
      sh:name "폴백 규칙 여부" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:periodChangeThreshold ;
      sh:datatype xsd:decimal ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "기간 변화 임계값" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:resolvedChangeMeasure ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "해석 ChangeMeasure" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ExplicitChangeMeasure ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "non-fallback rule must have appliesToValueType; fallback rule must not (D-9)"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  OPTIONAL { $this cla:isFallbackThresholdRule ?fb }
  FILTER (
    (BOUND(?fb) && ?fb = true && EXISTS { $this cla:appliesToValueType ?vt }) ||
    ((!BOUND(?fb) || ?fb != true) && NOT EXISTS { $this cla:appliesToValueType ?vt })
  )
}""" ;
    ] ;
.
cla:TM_always
  a skos:Concept ;
  skos:inScheme cla:TriggerMode ;
  skos:notation "always" ;
  skos:prefLabel "항상 포함"@ko ;
.
cla:TM_when_triggered
  a skos:Concept ;
  skos:inScheme cla:TriggerMode ;
  skos:notation "when_triggered" ;
  skos:prefLabel "조건 충족 시"@ko ;
.
cla:TriggerCondition
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "trigger condition"@en ;
  skos:editorialNote "조건 평가 대상 지표는 TriggerCondition에 두지 않음. Metric→hasTriggerPolicy 또는 CIG→hasActivationMetric 경로로 연결된 지표의 시계열·업계값을 엔진이 사용. default policy의 period_change는 changeMeasure 없음(TriggerPolicy.defaultThresholdMode). 지표별 period_change는 changeMeasure(ExplicitChangeMeasure) 필수." ;
  skos:prefLabel "트리거 조건"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path spin:rule ;
      skos:editorialNote "Phase 1 런타임 미사용. 향후 SPIN 규칙 평가(Phase 2)용 슬롯."@ko ;
      sh:class sp:Construct ;
      sh:maxCount 1 ;
      sh:name "spin 규칙" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:changeMeasure ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:name "기간 변화 측정" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ExplicitChangeMeasure ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:conditionType ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "조건 유형" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:ConditionType ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:industryComparison ;
      sh:class skos:Concept ;
      sh:defaultValue cla:ICM_abs_diff ;
      sh:maxCount 1 ;
      sh:name "업계 비교 방식" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:IndustryComparisonMode ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:thresholdValue ;
      sh:datatype xsd:decimal ;
      sh:maxCount 1 ;
      sh:name "임계값" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "changeMeasure only allowed for period_change_threshold"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:changeMeasure ?cm .
  FILTER NOT EXISTS { $this cla:conditionType cla:CT_period_change_threshold }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "default policy period_change_threshold must not have changeMeasure"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_period_change_threshold .
  $this cla:changeMeasure ?cm .
  ?tp cla:hasTriggerCondition $this ;
      cla:isDefaultTriggerPolicy true .
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "default policy period_change_threshold must not have thresholdValue"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_period_change_threshold .
  $this cla:thresholdValue ?tv .
  ?tp cla:hasTriggerCondition $this ;
      cla:isDefaultTriggerPolicy true .
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "industryComparison only for industry_vs_company" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:industryComparison ?ic .
  FILTER NOT EXISTS { $this cla:conditionType cla:CT_industry_vs_company }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "industry_vs_company must not have changeMeasure" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_industry_vs_company .
  $this cla:changeMeasure ?cm .
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "industry_vs_company requires thresholdValue" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_industry_vs_company .
  FILTER NOT EXISTS { $this cla:thresholdValue ?v }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "non-default period_change_threshold requires changeMeasure"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_period_change_threshold .
  FILTER NOT EXISTS { $this cla:changeMeasure ?cm }
  FILTER NOT EXISTS {
    ?tp cla:hasTriggerCondition $this ;
        cla:isDefaultTriggerPolicy true .
  }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "period_change_threshold with thresholdValue requires changeMeasure on non-default policy"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_period_change_threshold .
  $this cla:thresholdValue ?tv .
  FILTER NOT EXISTS { $this cla:changeMeasure ?cm }
  FILTER NOT EXISTS {
    ?tp cla:hasTriggerCondition $this ;
        cla:isDefaultTriggerPolicy true .
  }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "removed conditionType notation (change_rate_threshold / change_abs_threshold)" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  {
    $this cla:conditionType <https://hit.hanati.co.kr/ontology/cla#CT_change_rate_threshold> .
  } UNION {
    $this cla:conditionType <https://hit.hanati.co.kr/ontology/cla#CT_change_abs_threshold> .
  }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "sign_cross_zero must not have changeMeasure or thresholdValue" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_sign_cross_zero .
  OPTIONAL { $this cla:changeMeasure ?cm }
  OPTIONAL { $this cla:thresholdValue ?tv }
  FILTER ( BOUND(?cm) || BOUND(?tv) )
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "sign_cross_zero must not have thresholdValue" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:conditionType cla:CT_sign_cross_zero .
  $this cla:thresholdValue ?v .
}""" ;
    ] ;
.
cla:TriggerMode
  a skos:ConceptScheme ;
  skos:prefLabel "트리거 모드"@ko ;
.
cla:TriggerPolicy
  a owl:Class ;
  a sh:NodeShape ;
  rdfs:subClassOf owl:Thing ;
  skos:altLabel "trigger policy"@en ;
  skos:editorialNote "triggerMode=always: 조건 평가 생략·항상 포함(명시적 opt-in). triggerMode=when_triggered: combine으로 조건 평가·조건≥1. Metric에 hasTriggerPolicy 없음=필터 없이 전체 포함(always와 다름). when_triggered인데 조건 없음=런타임 제외·SHACL 위반." ;
  skos:prefLabel "트리거 정책"@ko ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:combineOperator ;
      sh:defaultValue cla:any ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "조건 조합 방식" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:CombineOperator ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:defaultThresholdMode ;
      sh:class skos:Concept ;
      sh:maxCount 1 ;
      sh:name "기본 임계값 모드" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:DefaultThresholdMode ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:hasTriggerCondition ;
      sh:class cla:TriggerCondition ;
      sh:name "할당 트리거 조건" ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isDefaultTriggerPolicy ;
      sh:datatype xsd:boolean ;
      sh:maxCount 1 ;
      sh:name "기본 트리거 정책 여부" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:isSharedPolicy ;
      sh:datatype xsd:boolean ;
      sh:maxCount 1 ;
      sh:name "공유 정책 여부" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:policyKey ;
      sh:datatype xsd:string ;
      sh:maxCount 1 ;
      sh:name "정책 공유 키" ;
    ] ;
  sh:property [
      a sh:PropertyShape ;
      sh:path cla:triggerMode ;
      sh:defaultValue cla:TM_when_triggered ;
      sh:maxCount 1 ;
      sh:minCount 1 ;
      sh:name "트리거 모드" ;
      sh:node [
          a sh:NodeShape ;
          sh:property [
              sh:path skos:inScheme ;
              sh:hasValue cla:TriggerMode ;
            ] ;
        ] ;
      sh:nodeKind sh:IRI ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "always must not have TriggerCondition" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:triggerMode cla:TM_always .
  $this cla:hasTriggerCondition ?c .
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "default TriggerPolicy requires defaultThresholdMode when period_change present"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:isDefaultTriggerPolicy true .
  ?tc cla:conditionType cla:CT_period_change_threshold .
  $this cla:hasTriggerCondition ?tc .
  FILTER NOT EXISTS { $this cla:defaultThresholdMode ?dtm }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "defaultThresholdMode only allowed on default TriggerPolicy"@ko ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:defaultThresholdMode ?dtm .
  FILTER NOT EXISTS { $this cla:isDefaultTriggerPolicy true }
}""" ;
    ] ;
  sh:sparql [
      a sh:SPARQLConstraint ;
      sh:message "when_triggered requires at least one TriggerCondition" ;
      sh:prefixes <https://hit.hanati.co.kr/ontology/cla> ;
      sh:select """SELECT $this WHERE {
  $this cla:triggerMode cla:TM_when_triggered .
  FILTER NOT EXISTS { $this cla:hasTriggerCondition ?c }
}""" ;
    ] ;
.
cla:UC_Currency
