.
cla:guidanceText
  a owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  skos:prefLabel "해석 가이드"@ko ;
.
cla:hasActivationMetric
  a owl:ObjectProperty ;
  rdfs:domain cla:CompositeInterpretationGroup ;
  rdfs:range cla:Metric ;
  rdfs:subPropertyOf cla:hasGroupMetric ;
  skos:prefLabel "복합 해석 대표 지표"@ko ;
.
cla:hasFallbackThresholdRule
  a owl:ObjectProperty ;
  rdfs:domain cla:PeriodChangeThresholdPolicy ;
  rdfs:range cla:PeriodChangeThresholdRule ;
  skos:prefLabel "폴백 임계값 규칙"@ko ;
.
cla:hasFormula
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:Formula ;
  skos:prefLabel "지표 계산식"@ko ;
.
cla:hasGroupMetric
  a owl:ObjectProperty ;
  rdfs:domain cla:CompositeInterpretationGroup ;
  rdfs:range cla:Metric ;
  owl:inverseOf cla:memberOfGroup ;
  skos:prefLabel "복합 해석 지표"@ko ;
.
cla:hasOperand
  a owl:ObjectProperty ;
  rdfs:domain cla:Formula ;
  rdfs:range cla:Metric ;
  skos:prefLabel "산식 활용 지표"@ko ;
.
cla:hasRelatedMetric
  a owl:SymmetricProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:Metric ;
  skos:editorialNote "데이터 구축 시 직접 값을 넣는 방식이 아니라 하위 프로퍼티로부터 추론 받아서 연결 짓는 방식으로 구축 설계 중" ;
  skos:prefLabel "관련 지표"@ko ;
.
cla:hasSourceMetric
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:Metric ;
  rdfs:subPropertyOf cla:hasRelatedMetric ;
  owl:propertyChainAxiom (
      cla:hasFormula
      cla:hasOperand
    ) ;
  skos:editorialNote "데이터 구축 시 직접 값을 넣는 방식이 아니라 Formula 인스턴스로부터 추론 받아서 연결 짓는 방식으로 구축 설계 중" ;
  skos:prefLabel "계산 원천 지표"@ko ;
.
cla:hasTargetGroup
  a owl:ObjectProperty ;
  rdfs:domain cla:AnalyticalView ;
  rdfs:range cla:CompositeInterpretationGroup ;
  skos:prefLabel "분석 대상 복합 해석 그룹"@ko ;
.
cla:hasTargetMetric
  a owl:ObjectProperty ;
  rdfs:domain cla:AnalyticalView ;
  rdfs:range cla:Metric ;
  owl:inverseOf cla:isTargetMetricOf ;
  skos:prefLabel "분석 대상 지표"@ko ;
.
cla:hasTriggerCondition
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range cla:TriggerCondition ;
  skos:prefLabel "트리거 조건"@ko ;
.
cla:hasTriggerPolicy
  a owl:ObjectProperty ;
  rdfs:range cla:TriggerPolicy ;
  skos:prefLabel "트리거 정책"@ko ;
.
cla:hasValueTypeThresholdRule
  a owl:ObjectProperty ;
  rdfs:domain cla:PeriodChangeThresholdPolicy ;
  rdfs:range cla:PeriodChangeThresholdRule ;
  skos:prefLabel "value_type별 임계값 규칙"@ko ;
.
cla:includesMetric
  a owl:ObjectProperty ;
  rdfs:domain cla:CompositeInterpretationGroup ;
  rdfs:range cla:Metric ;
  rdfs:subPropertyOf cla:hasGroupMetric ;
  skos:prefLabel "복합 해석 포함 지표"@ko ;
.
cla:industryComparison
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerCondition ;
  rdfs:range skos:Concept ;
  skos:prefLabel "업계 비교 방식"@ko ;
.
cla:isDefaultTriggerPolicy
  a owl:DatatypeProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range xsd:boolean ;
  skos:definition "_defaults.triggers에서 materialize된 TriggerPolicy 표식."@ko ;
  skos:prefLabel "기본 트리거 정책 여부"@ko ;
.
cla:isEnabled
  a owl:DatatypeProperty ;
  rdfs:domain cla:CompositeInterpretationGroup ;
  rdfs:range xsd:boolean ;
  skos:definition "false이면 복합 해석 그룹을 런타임에서 비활성 처리. YAML enabled 생략 시 true로 materialize." ;
  skos:prefLabel "활성 여부"@ko ;
.
cla:isFallbackThresholdRule
  a owl:DatatypeProperty ;
  rdfs:domain cla:PeriodChangeThresholdRule ;
  rdfs:range xsd:boolean ;
  skos:definition "metricValueType 없을 때 사용하는 폴백 임계값 규칙"@ko ;
.
cla:isInputMetric
  a owl:DatatypeProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range xsd:boolean ;
  skos:editorialNote """JSON 입력데이터에 직접적으로 존재한 데이터인지 확인하기 위한 정보
- 1차로는 YAML 파일에 formula 정보가 업는 값을 true로 보고, 2차로 실제 데이터 검토하여 업데이트 하는 방향으로 데이터 개선 예상""" ;
  skos:prefLabel "입력 지표 여부"@ko ;
.
cla:isReportable
  a owl:DatatypeProperty ;
  rdfs:domain cla:AnalyticalView ;
  rdfs:range xsd:boolean ;
  skos:prefLabel "사전 계산"@ko ;
.
cla:isSharedPolicy
  a owl:DatatypeProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range xsd:boolean ;
  skos:prefLabel "공유 정책 여부"@ko ;
.
cla:isTargetMetricOf
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:AnalyticalView ;
  owl:inverseOf cla:hasTargetMetric ;
  skos:prefLabel "소속 분석 관점"@ko ;
.
cla:memberOfGroup
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:CompositeInterpretationGroup ;
  owl:inverseOf cla:hasGroupMetric ;
  skos:prefLabel "포함된 복합 해석 그룹"@ko ;
.
cla:metricCategory
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range skos:Concept ;
  skos:editorialNote "정확한 활용방안이 결정되지 않은 지표로 일단 필요성 고민 측면에서 정의만 진행" ;
  skos:prefLabel "지표의 분류 유형"@ko ;
.
cla:metricId
  a owl:DatatypeProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range xsd:string ;
  skos:prefLabel "지표 식별자"@ko ;
.
cla:metricValueType
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range skos:Concept ;
  skos:prefLabel "지표 값 유형"@ko ;
.
cla:periodChangeThreshold
  a owl:DatatypeProperty ;
  rdfs:domain cla:PeriodChangeThresholdRule ;
  rdfs:range xsd:decimal ;
  skos:definition "period_change_thresholds 테이블의 value_type별 임계값"@ko ;
.
cla:policyKey
  a owl:DatatypeProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range xsd:string ;
  skos:editorialNote "동일 mode+combine+conditions fingerprint. 빌드 시 dedup 키." ;
  skos:prefLabel "정책 공유 키"@ko ;
.
cla:resolvedChangeMeasure
  a owl:ObjectProperty ;
  rdfs:domain cla:PeriodChangeThresholdRule ;
  rdfs:range skos:Concept ;
  skos:definition "DTM_auto 시 실제 비교에 쓰는 ChangeMeasure"@ko ;
.
cla:sameGroupMetric
  a owl:SymmetricProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range cla:Metric ;
  rdfs:subPropertyOf cla:hasRelatedMetric ;
  owl:propertyChainAxiom (
      cla:memberOfGroup
      cla:hasGroupMetric
    ) ;
  skos:editorialNote """- 데이터 구축 시 직접 값을 넣는 방식이 아니라 CompositeInterpretationGroup 인스턴스에 연결된 지표정보로부터 추론 받아서 연결 짓는 방식으로 구축 설계 중
- 해당 프로퍼티로 추론된 (S, O) 쌍에서 S와 O가 동일 인스턴스인 경우도 추론되므로 주의가 필요함""" ;
  skos:prefLabel "동일 복합 해석 그룹 지표"@ko ;
.
cla:thresholdValue
  a owl:DatatypeProperty ;
  rdfs:domain cla:TriggerCondition ;
  rdfs:range xsd:decimal ;
  skos:editorialNote "conditionType별 필수 여부는 TriggerCondition NodeShape SHACL 참고. period_change 임계는 PeriodChangeThresholdRule에서 엔진이 조회." ;
  skos:prefLabel "임계값"@ko ;
.
cla:triggerMode
  a owl:ObjectProperty ;
  rdfs:domain cla:TriggerPolicy ;
  rdfs:range skos:Concept ;
  skos:prefLabel "트리거 모드"@ko ;
.
cla:unit
  a owl:ObjectProperty ;
  rdfs:domain cla:Metric ;
  rdfs:range skos:Concept ;
  skos:prefLabel "지표 기준 단위"@ko ;
.
cla:unitLabel
  a rdf:Property ;
  a owl:AnnotationProperty ;
  rdfs:range xsd:string ;
  rdfs:subPropertyOf rdfs:label ;
.
cla:viewRole
  a owl:ObjectProperty ;
  rdfs:domain cla:AnalyticalView ;
  rdfs:range skos:Concept ;
  skos:prefLabel "관점 역할"@ko ;
.
